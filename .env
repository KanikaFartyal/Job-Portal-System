PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/jobportal
JWT_SECRET=jobportalsecret

# ===== EMAIL CONFIGURATION =====
# To send real verification emails to Gmail inboxes, follow these steps:
#
# STEP 1: Enable 2-Factor Authentication
#   - Go to https://myaccount.google.com/security
#   - Scroll to "2-Step Verification" and enable it
#
# STEP 2: Generate App Password
#   - Go to https://myaccount.google.com/apppasswords
#   - Select "Mail" and "Windows Computer" (or your device)
#   - Google will generate a 16-character password
#   - Copy this password (it's in the popup)
#
# STEP 3: Update these credentials
#   - EMAIL_USER = your actual Gmail address (e.g., your.email@gmail.com)
#   - EMAIL_PASS = the 16-character app password from Step 2 (no spaces)
#
# Example:
#   EMAIL_USER=john.doe@gmail.com
#   EMAIL_PASS=abcd efgh ijkl mnop  (but without spaces: abcdefghijklmnop)

EMAIL_USER=your@gmail.com
EMAIL_PASS=your_16_char_app_password

# Note: If EMAIL_USER is not configured (or is the placeholder),
# the system will automatically use Ethereal test service for development

# Frontend URL for email links
FRONTEND_URL=http://localhost:3000
